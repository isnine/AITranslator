    "A nimble brown fox leapt over the lazy dog. This sentence contains every letter of the English alphabet." : {
      "comment" : "Snapshot mock polish result",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قفز ثعلب بني رشيق فوق الكلب الكسول. تحتوي هذه الجملة على كل حرف من حروف الأبجدية الإنجليزية."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En adræt brun ræv sprang over den dovne hund. Denne sætning indeholder alle bogstaver i det engelske alfabet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein flinker brauner Fuchs sprang über den faulen Hund. Dieser Satz enthält jeden Buchstaben des englischen Alphabets."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A nimble brown fox leapt over the lazy dog. This sentence contains every letter of the English alphabet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un ágil zorro marrón saltó sobre el perro perezoso. Esta frase contiene todas las letras del alfabeto inglés."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un agile renard brun a sauté par-dessus le chien paresseux. Cette phrase contient toutes les lettres de l'alphabet anglais."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seekor rubah cokelat yang cekatan melompati anjing malas. Kalimat ini mengandung semua huruf dalam alfabet Inggris."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una volpe marrone agile saltò sopra il cane pigro. Questa frase contiene ogni lettera dell'alfabeto inglese."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "機敏な茶色の狐が怠けた犬を飛び越えました。この文には英語のアルファベットのすべての文字が含まれています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "민첩한 갈색 여우가 게으른 개를 뛰어넘었습니다. 이 문장은 영어 알파벳의 모든 글자를 포함합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En smidig brun rev hoppet over den late hunden. Denne setningen inneholder alle bokstavene i det engelske alfabetet."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een lenige bruine vos sprong over de luie hond. Deze zin bevat alle letters van het Engelse alfabet."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma ágil raposa marrom saltou sobre o cachorro preguiçoso. Esta frase contém todas as letras do alfabeto inglês."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En smidig brun räv hoppade över den lata hunden. Denna mening innehåller alla bokstäver i det engelska alfabetet."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çevik kahverengi tilki tembel köpeğin üzerinden atladı. Bu cümle İngiliz alfabesinin her harfini içerir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "那只敏捷的棕色狐狸跃过了那条懒狗。这个句子包含了英文字母表里的每一个字母。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一隻靈活的棕色狐狸跳過了一隻懶狗。這句話包含了英文字母的每一個字母。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一隻敏捷的棕色狐狸跳過了懶狗。這個句子包含了英文字母的所有字母。"
          }
        }
      }
    },
