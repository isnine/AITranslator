        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seus dados são criptografados durante a transferência e não são armazenados após o processamento."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dina data krypteras under överföring och lagras inte efter bearbetning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verileriniz aktarım sırasında şifrelenir ve işlendikten sonra saklanmaz."
