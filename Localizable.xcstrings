    "The quick brown fox jumps over the lazy dog. This sentence contains every letter of the alphabet." : {
      "comment" : "Snapshot mock input text\nSnapshot mock translation result",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الثعلب البني السريع يقفز فوق الكلب الكسول. تحتوي هذه الجملة على كل حرف من أحرف الأبجدية."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den hurtige brune ræv hopper over den dovne hund. Denne sætning indeholder alle bogstaverne i alfabetet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der schnelle braune Fuchs springt über den faulen Hund. Dieser Satz enthält jeden Buchstaben des Alphabets."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The quick brown fox jumps over the lazy dog. This sentence contains every letter of the alphabet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El rápido zorro marrón salta sobre el perro perezoso. Esta oración contiene todas las letras del alfabeto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le vif renard brun saute par-dessus le chien paresseux. Cette phrase contient toutes les lettres de l'alphabet."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rubah cokelat yang cepat melompati anjing malas. Kalimat ini mengandung setiap huruf alfabet."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La veloce volpe marrone salta sopra il cane pigro. Questa frase contiene tutte le lettere dell'alfabeto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "素早い茶色の狐が怠け者の犬を飛び越える。この文章にはアルファベットのすべての文字が含まれています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "빠른 갈색 여우가 게으른 개를 뛰어넘습니다. 이 문장은 알파벳의 모든 글자를 포함하고 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den raske brune reven hopper over den late hunden. Denne setningen inneholder alle bokstavene i alfabetet."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De snelle bruine vos springt over de luie hond. Deze zin bevat alle letters van het alfabet."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A rápida raposa marrom pula sobre o cão preguiçoso. Esta frase contém todas as letras do alfabeto."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den snabba bruna räven hoppar över den lata hunden. Denna mening innehåller varje bokstav i alfabetet."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hızlı kahverengi tilki tembel köpeğin üzerinden atlar. Bu cümlede alfabenin her harfi bulunur."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "敏捷的棕色狐狸跳过了懒惰的狗。这句话包含了字母表中的每个字母。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速的棕色狐狸跳過懶狗。此句包含所有英文字母。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速的褐色狐狸跳過懶狗。此句包含所有字母。"
          }
        }
      }
    },
