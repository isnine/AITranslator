    },
    "This will replace your current actions with the built-in defaults. Any custom changes will be lost." : {
      "comment" : "Reset configuration confirmation message",
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى استبدال إجراءاتك الحالية بالإعدادات الافتراضية المضمّنة. سيتم فقد أي تغييرات مخصصة."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette vil erstatte dine nuværende handlinger med de indbyggede standarder. Eventuelle brugerdefinerede ændringer går tabt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ersetzt deine aktuellen Aktionen mit den integrierten Standardwerten. Alle benutzerdefinierten Änderungen gehen verloren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will replace your current actions with the built-in defaults. Any custom changes will be lost."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto reemplazará tus acciones actuales con las configuraciones predeterminadas integradas. Se perderán los cambios personalizados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela remplacera vos actions actuelles par les paramètres prédéfinis intégrés. Toute modification personnalisée sera perdue."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ini akan mengganti tindakan Anda saat ini dengan pengaturan bawaan. Perubahan khusus akan hilang."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo sostituirà le tue azioni attuali con i valori predefiniti integrati. Eventuali modifiche personalizzate andranno perse."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現行のアクションが組み込みデフォルトに置き換えられます。カスタマイズした変更は失われます。"
