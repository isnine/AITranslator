    "Are you sure you want to delete this action? This cannot be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حذف هذا الإجراء؟ لا يمكن التراجع عن هذا."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på, at du vil slette denne handling? Dette kan ikke fortrydes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie diese Aktion löschen möchten? Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to delete this action? This cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea eliminar esta acción? Esto no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir supprimer cette action ? Cela ne peut pas être annulé."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apakah Anda yakin ingin menghapus tindakan ini? Ini tidak dapat dibatalkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler eliminare questa azione? Questo non può essere annullato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この操作を削除してもよろしいですか？これは元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 작업을 삭제하시겠습니까? 이 작업은 취소할 수 없습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil slette denne handlingen? Dette kan ikke angres."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weet je zeker dat je deze actie wilt verwijderen? Dit kan niet ongedaan worden gemaakt."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que deseja excluir esta ação? Isso não pode ser desfeito."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Är du säker på att du vill ta bort den här åtgärden? Det här kan inte ångras."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu işlemi silmek istediğinizden emin misiniz? Bu işlem geri alınamaz."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "确定删除此操作？此操作无法撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您確定要刪除此操作嗎？此操作無法撤銷。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "確定要刪除此操作嗎？此操作無法還原。"
          }
        }
      }
    },
