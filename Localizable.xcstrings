    "Select text in any app to instantly translate it. TLingo needs Accessibility permission to detect your text selections." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدد نصًا في أي تطبيق لترجمته على الفور. يحتاج MyAppName إلى إذن الوصول للكشف عن تحديدات النص الخاصة بك."
          }
        },
        "de" : {
          "stringUnit" : {
