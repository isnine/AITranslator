        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "例: \"形式的な日本語に翻訳し、横に比較を表示する\""
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "예: \"공식 일본어로 번역하고 나란히 비교 보기\""
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "f.eks. \"Oversett til formelt japansk og vis sammenligning side om side\""
