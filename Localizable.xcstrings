        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 작업이 내장 기본값으로 대체됩니다. 사용자 지정 변경 사항은 모두 삭제됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette vil erstatte dine nåværende handlinger med de innebygde standardene. Tilpassede endringer vil gå tapt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hierdoor worden je huidige acties vervangen door de ingebouwde standaarden. Alle aangepaste wijzigingen gaan verloren."
