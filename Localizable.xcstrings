          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "e.g. \"Translate to formal Japanese and show side-by-side comparison\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "p.ej. \"Traducir al japonés formal y mostrar comparación lado a lado\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ex : \"Traduire en japonais formel et montrer une comparaison côte à côte\""
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "misalnya: \"Terjemahkan ke bahasa Jepang formal dan tunjukkan perbandingan berdampingan\""
