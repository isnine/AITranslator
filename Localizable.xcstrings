            "value" : "Dataene dine er kryptert under overføring og lagres ikke etter behandling."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uw gegevens worden tijdens verzending versleuteld en na verwerking niet opgeslagen."
