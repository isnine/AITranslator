    "Your data is encrypted in transit and not stored after processing." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم تشفير بياناتك أثناء النقل ولا يتم تخزينها بعد المعالجة."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dine data er krypteret under transit og gemmes ikke efter behandling."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre Daten werden während der Übertragung verschlüsselt und nach der Verarbeitung nicht gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your data is encrypted in transit and not stored after processing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus datos están encriptados en tránsito y no se almacenan después del procesamiento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos données sont cryptées pendant le transfert et ne sont pas stockées après traitement."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data Anda dienkripsi saat transit dan tidak disimpan setelah diproses."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I tuoi dati vengono crittografati durante il trasferimento e non vengono archiviati dopo l'elaborazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "データは転送中に暗号化され、処理後は保存されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "귀하의 데이터는 전송 중 암호화되며 처리 후에는 저장되지 않습니다."
