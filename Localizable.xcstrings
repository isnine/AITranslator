    "You have unsaved changes. Are you sure you want to discard them?" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لديك تغييرات غير محفوظة. هل أنت متأكد أنك تريد تجاهلها؟"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har ikke-gemte ændringer. Er du sikker på, at du vil kassere dem?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben nicht gespeicherte Änderungen. Möchten Sie diese wirklich verwerfen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have unsaved changes. Are you sure you want to discard them?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tienes cambios sin guardar. ¿Estás seguro de que quieres descartarlos?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez des modifications non enregistrées. Êtes-vous sûr de vouloir les abandonner ?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda memiliki perubahan yang belum disimpan. Apakah Anda yakin ingin menghapusnya?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai modifiche non salvate. Sei sicuro di volerle annullare?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存されていない変更があります。本当に破棄してよろしいですか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저장되지 않은 변경 사항이 있습니다. 삭제하시겠습니까?"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har ulagrede endringer. Er du sikker på at du vil forkaste dem?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "U heeft niet-opgeslagen wijzigingen. Weet u zeker dat u ze wilt verwijderen?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você tem alterações não salvas. Tem certeza de que deseja descartá-las?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har osparade ändringar. Är du säker på att du vill ta bort dem?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaydedilmemiş değişiklikleriniz var. Bunları silmek istediğinizden emin misiniz?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
