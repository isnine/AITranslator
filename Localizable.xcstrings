        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecciona texto en cualquier aplicación para traducirlo instantáneamente. MyAppName necesita permiso de accesibilidad para detectar tus selecciones de texto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sélectionnez du texte dans n'importe quelle application pour le traduire instantanément. MyAppName a besoin de la permission d'accessibilité pour détecter vos sélections de texte."
          }
