# Snapfile — Fastlane snapshot configuration for TLingo

# Devices to capture screenshots on
devices([
  "iPhone 16 Pro"                            # 6.3" display (6.1" class for App Store)
])

# Languages to capture
languages([
  "en-US",
  "zh-Hans",
  "ja",
  "ko",
  "de"
])

# Pin to iOS 26 runtime
ios_version("26.0")

# Xcode scheme for UI tests
scheme("TLingoUITests")
project("./AITranslator.xcodeproj")

# Output directory
output_directory("./fastlane/screenshots")

# Clear previous screenshots
# Note: set to false to preserve backgrounds/gradient.png
# The screenshots lane handles cleanup manually
clear_previous_screenshots(false)

# Stop after first error (set false for CI)
stop_after_first_error(true)

# Dark mode (optional — set to true for dark mode screenshots)
dark_mode(false)

# Number of concurrent simulators
concurrent_simulators(true)

# Override status bar for clean screenshots
override_status_bar(true)
override_status_bar_arguments("--time 9:41 --dataNetwork wifi --wifiMode active --batteryState charged --batteryLevel 100")

# Launch arguments passed to the app
launch_arguments(["-FASTLANE_SNAPSHOT"])

# Localize simulator (ensures system language matches)
localize_simulator(true)

# Disable animations for faster/cleaner screenshots
disable_slide_to_type(true)
